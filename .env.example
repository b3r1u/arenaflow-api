# ─── Banco de dados ───────────────────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:senha@localhost:5432/arenaflow?schema=public"

# ─── Firebase Admin ───────────────────────────────────────────────────────────
# Caminho para o arquivo JSON da service account do Firebase
# Gere em: Firebase Console → Configurações do projeto → Contas de serviço → Gerar nova chave
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URLs dos frontends separadas por vírgula
ALLOWED_ORIGINS="http://localhost:4200,http://localhost:4201"
