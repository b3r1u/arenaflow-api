generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Usuário ──────────────────────────────────────────────────────────────────
model User {
  id            String         @id @default(uuid())
  firebase_uid  String         @unique
  email         String         @unique
  name          String?
  phone         String?
  cpf           String?
  role          Role           @default(CLIENT)
  establishment Establishment?
  subscription  Subscription?
  reviews       Review[]
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
}

enum Role {
  ADMIN
  CLIENT
}

// ─── Planos ───────────────────────────────────────────────────────────────────
model Plan {
  id            String         @id @default(uuid())
  slug          String         @unique   // free | essencial | pro | business
  name          String
  price         Float
  max_courts    Int?                     // null = ilimitado
  features      String[]
  subscriptions Subscription[]
}

// ─── Assinatura ───────────────────────────────────────────────────────────────
model Subscription {
  id            String             @id @default(uuid())
  user_id       String             @unique
  user          User               @relation(fields: [user_id], references: [id])
  plan_id       String
  plan          Plan               @relation(fields: [plan_id], references: [id])
  status        SubscriptionStatus @default(TRIAL)
  trial_ends_at DateTime?
  starts_at     DateTime           @default(now())
  ends_at       DateTime?
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

// ─── Estabelecimento (= Arena no app cliente) ─────────────────────────────────
model Establishment {
  id            String   @id @default(uuid())
  owner_id      String   @unique
  owner         User     @relation(fields: [owner_id], references: [id])
  name          String
  city          String?
  neighborhood  String?
  address       String?
  phone         String?
  description   String?
  sports        String[]
  open_hours    String?
  logo_color    String   @default("#22a55c")
  logo_initials String?
  logo_url      String?
  rating        Float    @default(0)
  reviews_count Int      @default(0)
  price_from    Float?
  price_to      Float?
  active        Boolean  @default(true)

  // Política de cancelamento
  cancel_policy_enabled Boolean @default(false)
  cancel_limit_hours    Float   @default(0)      // horas decimais (ex: 1.5 = 1h30m)
  cancel_fee_percent    Int     @default(0)       // 0–100

  courts        Court[]
  reviews       Review[]
  financial     FinancialInfo?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

// ─── Informações Financeiras ──────────────────────────────────────────────────
model FinancialInfo {
  id                   String          @id @default(uuid())
  establishment_id     String          @unique
  establishment        Establishment   @relation(fields: [establishment_id], references: [id], onDelete: Cascade)

  account_holder       String                        // Nome do titular
  document_type        DocumentType                  // CPF ou CNPJ
  document_encrypted   String                        // Documento criptografado AES-256-GCM (LGPD)

  pix_key_type         PixKeyType                    // Tipo da chave PIX
  pix_key_encrypted    String                        // Chave PIX criptografada (LGPD)

  // Dados de contato e pessoais (para pré-preenchimento do formulário)
  email                String?
  phone                String?
  birth_date           String?                       // Data de nascimento (CPF) — formato YYYY-MM-DD
  company_type         String?                       // Tipo de empresa (CNPJ): MEI, LIMITED, etc.

  // Campos KYC obrigatórios pelo Pagar.me (PF)
  mother_name              String?
  monthly_income           String?                   // valor em reais como string (ex: "5000")
  professional_occupation  String?

  // Endereço
  address              String?
  address_number       String?
  complement           String?
  province             String?
  postal_code          String?

  // Endereço complementar (obrigatório para Pagar.me)
  city                 String?
  state                String?                       // UF (ex: PE, SP)

  // Dados bancários (para pré-preenchimento)
  bank_code            String?
  bank_account_type    String?
  bank_agency          String?
  bank_agency_digit    String?
  bank_account         String?
  bank_account_digit   String?

  pagarme_recipient_id      String?                  // ID do recebedor no Pagar.me (rp_XXXXXXXXXXXXXXXX)
  bank_registered_at        DateTime?                // data em que o recebedor foi criado no Pagar.me
  status               FinancialStatus @default(PENDING_REVIEW)

  // LGPD — Rastreabilidade do consentimento
  lgpd_consent_at      DateTime                      // Timestamp do aceite
  lgpd_purpose         String          @default("Processamento de pagamentos para reservas de quadras esportivas")

  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt
}

enum DocumentType {
  CPF
  CNPJ
}

enum PixKeyType {
  CPF
  CNPJ
  EMAIL
  PHONE
  RANDOM
}

enum FinancialStatus {
  PENDING_REVIEW  // Dados enviados, aguardando análise
  ACTIVE          // Verificado — pode receber pagamentos
  SUSPENDED       // Conta suspensa
}

// ─── Quadra ───────────────────────────────────────────────────────────────────
model Court {
  id               String        @id @default(uuid())
  establishment_id String
  establishment    Establishment @relation(fields: [establishment_id], references: [id])
  name             String
  sport_type       String        // futevôlei | vôlei | beach tennis | ambos
  status           CourtStatus   @default(DISPONIVEL)
  hourly_rate      Float
  description      String?
  active           Boolean       @default(true)
  bookings         Booking[]
  mensalistas      Mensalista[]
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt
}

enum CourtStatus {
  DISPONIVEL
  BLOQUEADA
}

// ─── Reserva ──────────────────────────────────────────────────────────────────
model Booking {
  id                String               @id @default(uuid())
  arena_id          String
  court_id          String
  court             Court                @relation(fields: [court_id], references: [id])
  user_uid          String
  client_name       String
  client_phone      String?
  date              String               // YYYY-MM-DD
  start_hour        String               // HH:00
  end_hour          String               // HH:00
  duration_hours    Int
  total_amount      Float
  paid_amount       Float
  payment_option    String               // "50" | "100"
  payment_status    BookingPaymentStatus @default(PENDENTE)
  split_payment     Boolean              @default(false)
  num_players       Int?
  pagarme_order_id  String?
  pagarme_charge_id String?
  pix_qr_code       String?
  pix_qr_code_url   String?
  pix_expires_at    DateTime?
  payment_group     BookingPaymentGroup?
  canceled_at       DateTime?            // preenchido quando status = CANCELADO | ESTORNADO | CHARGEDBACK
  created_at        DateTime             @default(now())
  updated_at        DateTime             @updatedAt
}

enum BookingPaymentStatus {
  PENDENTE          // criada, aguardando pagamento
  PARCIAL           // pelo menos uma cota paga (split)
  SINAL_PAGO        // 50% pago, restante na arena
  PAGO              // 100% pago
  CANCELADO         // cancelado sem pagamento real
  ESTORNADO         // cancelado com estorno confirmado pelo Pagar.me
  CHARGEDBACK       // disputa iniciada pelo banco/portador do cartão
}

// ─── Grupo de Pagamento ───────────────────────────────────────────────────────
model BookingPaymentGroup {
  id            String                @id @default(uuid())
  booking_id    String                @unique
  booking       Booking               @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  payment_type  PaymentGroupType      // SPLIT | DEPOSIT
  total_amount  Int                   // em centavos
  paid_amount   Int                   @default(0)
  status        PaymentGroupStatus    @default(PENDENTE)
  splits        BookingPaymentSplit[]
  created_at    DateTime              @default(now())
  updated_at    DateTime              @updatedAt
}

enum PaymentGroupType {
  SPLIT    // 100% dividido entre jogadores
  DEPOSIT  // 50% de sinal
}

enum PaymentGroupStatus {
  PENDENTE
  PARCIAL
  PAGO
}

// ─── Cota individual de pagamento ─────────────────────────────────────────────
model BookingPaymentSplit {
  id                String           @id @default(uuid())
  group_id          String
  group             BookingPaymentGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)
  player_name       String
  amount            Int              // em centavos
  pagarme_order_id  String?
  pagarme_charge_id String?
  pix_qr_code       String?          // base64 do QR code
  pix_copy_paste    String?          // código copia e cola
  pix_expires_at    DateTime?
  status            SplitStatus      @default(PENDENTE)
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
}

enum SplitStatus {
  PENDENTE
  PAGO
  EXPIRADO
  ESTORNADO
  CHARGEDBACK
}

// ─── Avaliação de Arena ───────────────────────────────────────────────────────
model Review {
  id               String        @id @default(uuid())
  establishment_id String
  establishment    Establishment @relation(fields: [establishment_id], references: [id], onDelete: Cascade)
  user_id          String?
  user             User?         @relation(fields: [user_id], references: [id])
  booking_id       String?       // ID da reserva avaliada (uma avaliação por reserva)
  user_name        String        // nome denormalizado para exibição
  stars            Int           // 1–5
  comment          String?
  created_at       DateTime      @default(now())

  @@unique([user_id, booking_id])
}

// ─── Mensalista ───────────────────────────────────────────────────────────────
model Mensalista {
  id                String                   @id @default(uuid())
  court_id          String
  court             Court                    @relation(fields: [court_id], references: [id])
  user_uid          String                   // Firebase UID do cliente
  client_name       String
  client_phone      String?
  day_of_week       Int                      // 0=Dom 1=Seg 2=Ter 3=Qua 4=Qui 5=Sex 6=Sáb
  start_hour        String                   // HH:00
  end_hour          String                   // HH:00
  payment_date      DateTime?                // data em que o pagamento foi confirmado
  valid_until       DateTime?                // payment_date + 1 mês
  payment_status    MensalistaPaymentStatus  @default(PENDENTE)
  status            MensalistaStatus         @default(INATIVO)
  pagarme_order_id  String?
  pagarme_charge_id String?
  pix_qr_code       String?                  // URL da imagem do QR code
  pix_qr_code_url   String?                  // alias (compatibilidade com fluxo booking)
  pix_expires_at    DateTime?
  created_at        DateTime                 @default(now())
  updated_at        DateTime                 @updatedAt

  @@index([court_id, day_of_week, status])   // índice para consulta de disponibilidade
}

enum MensalistaStatus {
  ATIVO     // pagamento confirmado e dentro da vigência
  INATIVO   // cancelado manualmente pelo admin ou cliente
  EXPIRADO  // valid_until ultrapassado
}

enum MensalistaPaymentStatus {
  PENDENTE   // PIX gerado, aguardando pagamento
  PAGO       // pagamento confirmado pela Pagar.me
  CANCELADO  // cancelado/estornado
}
